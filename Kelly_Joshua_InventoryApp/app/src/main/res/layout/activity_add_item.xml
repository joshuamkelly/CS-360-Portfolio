<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F9FC"
    tools:context=".AddItemActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <TextView
            android:id="@+id/textAddItemTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Inventory Item"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#0D47A1"
            android:layout_marginTop="50dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/textAddItemSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enter item details to add a new record to the inventory grid."
            android:textSize="14sp"
            android:textColor="#555555"
            android:layout_marginBottom="32dp" />

        <EditText
            android:id="@+id/editItemName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Item Name"
            android:inputType="text"
            android:padding="14dp"
            android:backgroundTint="#0D47A1"
            android:layout_marginBottom="20dp" />

        <EditText
            android:id="@+id/editItemQuantity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Quantity"
            android:inputType="number"
            android:padding="14dp"
            android:backgroundTint="#0D47A1"
            android:layout_marginBottom="20dp" />

        <EditText
            android:id="@+id/editItemStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Status, such as In Stock or Low Stock"
            android:inputType="text"
            android:padding="14dp"
            android:backgroundTint="#0D47A1"
            android:layout_marginBottom="28dp" />

        <Button
            android:id="@+id/buttonSaveItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Item"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:layout_marginBottom="14dp" />

        <Button
            android:id="@+id/buttonCancelAddItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textAllCaps="false"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>