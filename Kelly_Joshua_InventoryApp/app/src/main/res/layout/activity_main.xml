<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F9FC"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/textAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Inventory Tracker"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#0D47A1"
            android:layout_marginTop="70dp" />

        <TextView
            android:id="@+id/textLoginSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign in to manage inventory and low-stock alerts"
            android:textSize="15sp"
            android:textColor="#555555"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="40dp" />

        <EditText
            android:id="@+id/editUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Username"
            android:inputType="text"
            android:padding="14dp"
            android:backgroundTint="#0D47A1"
            android:layout_marginBottom="20dp" />

        <EditText
            android:id="@+id/editPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Password"
            android:inputType="textPassword"
            android:padding="14dp"
            android:backgroundTint="#0D47A1"
            android:layout_marginBottom="28dp" />

        <Button
            android:id="@+id/buttonLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Log In"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:layout_marginBottom="14dp" />

        <Button
            android:id="@+id/buttonCreateAccount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textAllCaps="false"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/textLoginNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="New users can create an account using the username and password fields above."
            android:textSize="13sp"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_marginTop="30dp" />

    </LinearLayout>
</ScrollView>