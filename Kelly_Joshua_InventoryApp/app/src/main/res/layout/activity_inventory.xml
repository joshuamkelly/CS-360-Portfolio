<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F9FC"
    tools:context=".InventoryActivity">

    <LinearLayout
        android:id="@+id/inventoryRootLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/textInventoryTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Inventory Dashboard"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#0D47A1"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/textInventorySubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View, add, update, and delete inventory records."
            android:textSize="14sp"
            android:textColor="#555555"
            android:layout_marginBottom="22dp" />

        <Button
            android:id="@+id/buttonAddItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add New Item"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/buttonSmsSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SMS Notification Settings"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:id="@+id/gridHeaderRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#0D47A1"
            android:padding="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="Item"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="13sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Qty"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="13sp"
                android:gravity="center" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="Status"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="13sp"
                android:gravity="center" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="Actions"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="13sp"
                android:gravity="center" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/inventoryListLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/textEmptyInventory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No inventory items have been added yet."
            android:textSize="15sp"
            android:textColor="#666666"
            android:gravity="center"
            android:padding="18dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>